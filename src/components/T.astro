---
// Renders the English side of an { en, ja } content string. The site is
// English-only; the `ja` field is retained in the data but not displayed.
import type { LS } from '../data/content';

interface Props {
  text: LS;
  as?: keyof HTMLElementTagNameMap;
  class?: string;
}

const { text, as = 'span', class: className } = Astro.props;
const Tag = as as any;
---

<Tag class={className}>{text.en}</Tag>
