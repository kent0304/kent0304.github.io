---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Timeline from '../components/Timeline.astro';
import Recognition from '../components/Recognition.astro';
import Publications from '../components/Publications.astro';
import Stack from '../components/Stack.astro';
import Footer from '../components/Footer.astro';
---

<Base>
  <Nav />
  <main>
    <Hero />
    <Timeline />
    <Recognition />
    <Publications />
    <Stack />
  </main>
  <Footer />

  <!-- Scroll-reveal: progressively show .reveal elements as they enter view. -->
  <script>
    const els = document.querySelectorAll<HTMLElement>('.reveal');
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (reduce || !('IntersectionObserver' in window)) {
      els.forEach((el) => el.classList.add('is-visible'));
    } else {
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              io.unobserve(entry.target);
            }
          });
        },
        { rootMargin: '0px 0px -8% 0px', threshold: 0.05 }
      );
      // Stagger siblings slightly for a more orchestrated reveal.
      els.forEach((el, i) => {
        el.style.transitionDelay = `${Math.min((i % 6) * 60, 320)}ms`;
        io.observe(el);
      });
    }
  </script>
</Base>
